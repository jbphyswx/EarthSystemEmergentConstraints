{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbphyswx/EarthSystemEmergentConstraints/schema/constraint.schema.json",
  "title": "EmergentConstraint",
  "description": "A catalog record for a published emergent constraint definition.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "uuid",
    "alias",
    "title",
    "status",
    "citation",
    "predictor",
    "target",
    "relationship"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "alias": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "minLength": 3
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "contested", "confirmed_candidate", "withdrawn"]
    },
    "domain": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "realm": { "type": "string" }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["doi"],
      "properties": {
        "doi": { "type": "string", "minLength": 3 },
        "year": { "type": "integer" },
        "authors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "bibtex_key": { "type": "string" }
      }
    },
    "claim_provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "discovered_in": {
          "type": "array",
          "items": { "type": "string" }
        },
        "also_discussed_in": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "predictor": { "$ref": "#/$defs/quantity" },
    "target": { "$ref": "#/$defs/quantity" },
    "relationship": {
      "type": "object",
      "additionalProperties": true,
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "latex": { "type": "string" },
        "lean": { "type": "string" }
      }
    },
    "hall_assessment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "plausible_mechanism": { "type": "boolean" },
        "mechanism_verified": { "type": "boolean" },
        "out_of_sample_ok": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "assessments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["source", "verdict"],
        "properties": {
          "source": { "type": "string" },
          "verdict": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["role", "name"],
        "properties": {
          "role": { "type": "string" },
          "name": { "type": "string" },
          "vocab": { "type": "string" }
        }
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "caveats": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_aliases": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "anyOf": [
    { "required": ["hall_assessment"] },
    { "required": ["assessments"] }
  ],
  "$defs": {
    "quantity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "short_name", "units", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "short_name": { "type": "string", "minLength": 1 },
        "units": { "type": "string" },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
